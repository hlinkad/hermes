# Hermes Brain RAG env example
#
# Copy to deep_notes/.env for standalone RAG testing from this repo:
#   cp deep_notes/.env.example deep_notes/.env
#
# The app reads settings in this order:
#   explicit Settings(...) overrides > OS env > deep_notes/.env > ~/.hermes/.env > code defaults
#
# Do not commit real secrets. Keep API provider keys in ~/.hermes/.env or add them
# only to your ignored deep_notes/.env.

# === API ===
# Used by FastAPI endpoints and the Hermes plugin bearer token.
API_KEY=local-dev-change-me
API_PORT=8000

# === Sources ===
# Mac-host run: this is Denis's live Obsidian/Hermes Brain vault.
# Hermes Docker run: /Users/... is usually not mounted; leave VAULT_PATH empty
# in deep_notes/.env and rely on SOURCE_PATHS/BOOK_PATHS below.
VAULT_PATH=/Users/denishlinka/hermes/brain

# Extra text/extracted source roots and books/PDFs. Comma-separated.
SOURCE_PATHS=/gdrive/hermes-brain
BOOK_PATHS=/gdrive/hermes-brain/books,/gdrive/hermes-brain/pdf-docs
BOOK_PAGES_PER_CHUNK=3

# === Embedding ===
# Embedding models create vectors. Changing EMBED_MODEL requires rebuilding Qdrant.
EMBED_PROVIDER=ollama
EMBED_MODEL=bge-m3
OLLAMA_BASE_URL=http://127.0.0.1:11434
# If running deep_notes from the Hermes Docker backend instead of the Mac host, use:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OPENAI_API_KEY=sk-...  # only needed if EMBED_PROVIDER=openai

# === Vector Store ===
VECTOR_STORE_PROVIDER=qdrant
QDRANT_URL=http://127.0.0.1:6333
# If running deep_notes from the Hermes Docker backend instead of the Mac host, use:
# QDRANT_URL=http://host.docker.internal:6333
COLLECTION_NAME=hermes_brain

# === Chunking ===
CHUNK_STRATEGY=markdown
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# === Answer generation ===
# Retrieval-only commands such as deep_notes.hermes_context do not need an LLM key.
# /api/query and stream_answer need the configured provider's key.
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.5
# OPENAI_API_KEY=...
# Optional alternatives:
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
# LLM_PROVIDER=openrouter
# LLM_MODEL=<provider/model-id>
# OPENROUTER_API_KEY=...

# === Retrieval ===
SIMILARITY_TOP_K=8
AUTO_CONTEXT_ENABLED=true
AUTO_CONTEXT_TOP_K=5
AUTO_CONTEXT_MIN_SCORE=0.55
AUTO_CONTEXT_MAX_CHARS=3500

# === Hermes plugin hook ===
HERMES_BRAIN_RAG_CONTEXT_URL=http://127.0.0.1:8000/api/context
HERMES_BRAIN_RAG_API_KEY=local-dev-change-me
HERMES_BRAIN_RAG_TIMEOUT=2.5
