# Hermes Brain RAG env example
# Copy these entries into ~/.hermes/.env on the Mac host that runs Hermes/RAG.
# This file is documentation only; deep_notes does not read a live project .env.
# Add secret/API-key values manually. Do not commit or paste real keys into chat.

# Sources
# VAULT_PATH is the Obsidian vault / compiled brain.
# SOURCE_PATHS is a comma-separated list of extra text/extracted source roots.
VAULT_PATH=/Users/denishlinka/hermes
SOURCE_PATHS=/gdrive/hermes-brain

# Embeddings
# Embedding models are not chat/answer models. bge-m3 turns text chunks into vectors.
# Changing EMBED_MODEL requires rebuilding the Qdrant collection.
EMBED_PROVIDER=ollama
EMBED_MODEL=bge-m3
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Vector store
VECTOR_STORE_PROVIDER=qdrant
QDRANT_URL=http://127.0.0.1:6333
COLLECTION_NAME=hermes_brain

# Chunking
CHUNK_STRATEGY=markdown
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Answer generation
# DeepSeek reads retrieved context and writes answers. Changing LLM_MODEL does not require rebuilding Qdrant.
# Decision for Hermes Brain: use deepseek-v4-pro.
# Official direct DeepSeek OpenAI-compatible base URL: https://api.deepseek.com
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional alternatives for answer generation:
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
#
# LLM_PROVIDER=openrouter
# LLM_MODEL=<provider/model-id>
# OPENROUTER_API_KEY=

# Retrieval
SIMILARITY_TOP_K=8
